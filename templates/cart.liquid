<section class="cart-page">
  <div class="cart-page-inner">
    {%- if cart.item_count == 0 -%}
      <h1 class="cart-title">Your Cart</h1>
      <div class="cart-empty">
        <p>Your cart is empty.</p>
        <a href="{{ routes.root_url }}" class="btn btn-primary">Continue shopping</a>
      </div>
    {%- else -%}
      <h1 class="cart-title">Your Cart</h1>
      <p class="cart-subtitle">{{ cart.item_count }}{% if cart.item_count == 1 %} item{% else %} items{% endif %}</p>

      <form action="{{ routes.cart_url }}" method="post" novalidate>
        <div class="cart-items">
          {%- for item in cart.items -%}
            <div class="cart-item" data-cart-item="{{ item.key }}">
              <div class="cart-item-image">
                {%- if item.image -%}
                  <a href="{{ item.url }}"><img src="{{ item.image | image_url: width: 320 }}" alt="{{ item.product.title | escape }}" /></a>
                {%- endif -%}
              </div>
              <div class="cart-item-info">
                <h3><a href="{{ item.url }}" style="color: inherit; text-decoration: none;">{{ item.product.title }}</a></h3>
                {%- unless item.variant.title == 'Default Title' -%}
                  <p class="cart-item-variant">{{ item.variant.title }}</p>
                {%- endunless -%}
                <p class="cart-item-price">{{ item.original_price | money }}</p>
                <a href="{{ item.url_to_remove }}" class="cart-item-remove" data-cart-remove="{{ item.key }}">Remove</a>
              </div>
              <div class="qty-stepper" data-qty>
                <button type="button" aria-label="Decrease quantity" data-qty-dec>−</button>
                <input type="number" name="updates[{{ item.key }}]" value="{{ item.quantity }}" min="0" aria-label="Quantity" />
                <button type="button" aria-label="Increase quantity" data-qty-inc>+</button>
              </div>
              <div class="cart-item-line-total" data-line-total>{{ item.final_line_price | money }}</div>
            </div>
          {%- endfor -%}
        </div>

        <div class="cart-summary">
          <p class="cart-summary-note">Shipping and taxes calculated at checkout.</p>
          <div class="cart-totals">
            <div class="cart-totals-row">
              <span class="cart-totals-label">Subtotal</span>
              <span class="cart-totals-value" data-cart-subtotal>{{ cart.total_price | money }}</span>
            </div>
          </div>
          <p class="cart-preorder-note">
            <strong>Pre-order note:</strong>Everything is made in small batches, so please allow around 30–45 business days for shipping.
          </p>
          <div class="cart-actions">
            <a href="{{ routes.root_url }}" class="btn btn-secondary">Continue shopping</a>
            <button type="submit" name="checkout" class="btn btn-primary">Check out</button>
          </div>
        </div>
      </form>
    {%- endif -%}
  </div>
</section>
