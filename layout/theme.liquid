<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#EDE8E0" />
  <link rel="canonical" href="{{ canonical_url }}" />
  <link rel="icon" type="image/png" href="{{ 'praali_mark.png' | asset_url }}" />
  <link rel="apple-touch-icon" href="{{ 'praali_mark.png' | asset_url }}" />
  <title>
    {{ page_title }}
    {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
    {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
    {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
  </title>
  {%- if page_description %}<meta name="description" content="{{ page_description | escape }}" />{% endif -%}
  {{ content_for_header }}
  <link rel="stylesheet" href="{{ 'theme.css' | asset_url }}" />
</head>
<body class="template-{{ template | replace: '.', '-' | handleize }}">
  {% section 'header' %}

  <main>
    {{ content_for_layout }}
  </main>

  {% section 'footer' %}

  {% render 'product-modal' %}

  <div class="cart-toast" id="cartToast" role="status" aria-live="polite" hidden>Added to cart</div>

  <script src="{{ 'theme.js' | asset_url }}" defer></script>
</body>
</html>
