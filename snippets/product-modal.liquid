{%- comment -%}
  Renders the product detail modal markup. JS in theme.js populates the modal
  on click of a product card or "View details" link.
{%- endcomment -%}

<div class="modal" id="productModal" hidden>
  <div class="modal-overlay" data-modal-close></div>
  <div class="modal-content" role="dialog" aria-modal="true" aria-labelledby="modalTitle">
    <button class="modal-close" data-modal-close aria-label="Close">×</button>
    <div class="modal-grid">
      <div class="modal-image-col">
        <div class="modal-image" data-modal-image>
          <img class="modal-image-img" data-modal-image-img alt="" hidden />
          <span class="img-label" data-modal-image-label></span>
          <button class="carousel-arrow carousel-arrow-prev" data-carousel-prev aria-label="Previous image" hidden>‹</button>
          <button class="carousel-arrow carousel-arrow-next" data-carousel-next aria-label="Next image" hidden>›</button>
          <div class="carousel-counter" data-carousel-counter hidden></div>
        </div>
        <div class="modal-flat" data-modal-flat hidden>
          <img data-modal-flat-img alt="" />
        </div>
      </div>
      <div class="modal-details">
        <div class="modal-header-row">
          <div class="modal-header-text">
            <h2 class="modal-title" id="modalTitle"></h2>
            <p class="modal-price" data-modal-price></p>
          </div>
          <div class="modal-color-block">
            <div class="modal-swatches" data-modal-swatches></div>
            <p class="modal-color-label">COLOR : <span data-modal-color-name></span></p>
          </div>
        </div>

        <p class="modal-tagline" data-modal-tagline hidden></p>
        <ul class="modal-bullets" data-modal-bullets hidden></ul>
        <p class="modal-fit-note" data-modal-fit-note hidden></p>

        <div class="modal-section">
          <h4>Size</h4>
          <div class="size-options" data-modal-sizes></div>
        </div>

        <div class="modal-actions">
          <button class="btn btn-primary">Buy Now</button>
        </div>

        <div class="modal-section">
          <h4>Size Chart</h4>
          <p class="size-chart-desc">Fits true to size, with a little bit of stretch to accommodate for our everchanging bodies and lots of breath and movement.</p>
          <p class="size-chart-unit">ALL MEASUREMENTS ARE IN INCHES.</p>
          <table class="size-chart">
            <thead data-modal-size-thead></thead>
            <tbody data-modal-size-chart></tbody>
          </table>
          <div class="size-chart-footer">
            <h5>Don't see your size yet?</h5>
            <p>AS A NEW BRAND WE'RE THOUGHTFULLY GROWING OUR SIZE RANGE AND WOULD LOVE YOUR INPUT. IF YOU'D LIKE TO SEE YOUR SIZE IN FUTURE DROPS, LEAVE YOUR SIZING DETAILS <a href="https://forms.gle/4sgG7rauw2V9cXoq8" target="_blank" rel="noopener">HERE</a>.</p>
          </div>
        </div>
        <img class="modal-corner-mark" src="{{ 'praali_mark.png' | asset_url }}" alt="" />
      </div>
    </div>
  </div>
</div>

