{%- comment -%}
  Renders a product card for the homepage grid.
  Expects: product, idx
{%- endcomment -%}

{%- assign color_option_name = 'Color' -%}
{%- assign color_option = product.options_by_name[color_option_name] -%}
{%- assign default_variant = product.selected_or_first_available_variant -%}

<article class="product-card" data-product="{{ product.id }}">
  <button class="product-image" data-modal-open="{{ product.id }}" aria-label="View {{ product.title }} details">
    {%- if default_variant.featured_image -%}
      <img src="{{ default_variant.featured_image | image_url: width: 800 }}" alt="{{ product.title | escape }}" />
    {%- elsif product.featured_image -%}
      <img src="{{ product.featured_image | image_url: width: 800 }}" alt="{{ product.title | escape }}" />
    {%- else -%}
      <span class="img-label">{{ product.title }}</span>
    {%- endif -%}
  </button>

  {%- if color_option -%}
    <div class="color-swatches">
      {%- for value in color_option.values -%}
        {%- assign swatch_hex = value | downcase | replace: ' ', '-' -%}
        {%- case swatch_hex -%}
          {%- when 'cayenne' -%}{% assign hex = '#9C3E32' %}
          {%- when 'lilac' -%}{% assign hex = '#C4ADD4' %}
          {%- when 'sage-green' or 'sage' -%}{% assign hex = '#A9B48B' %}
          {%- else -%}{% assign hex = '#A9B48B' %}
        {%- endcase -%}
        <button class="swatch{% if forloop.last %} is-active{% endif %}" data-color="{{ forloop.index0 }}" style="background: {{ hex }};" aria-label="{{ value }}"></button>
      {%- endfor -%}
    </div>
  {%- endif -%}

  <h3 class="product-name">{{ product.title }}</h3>
  <p class="product-price">{{ default_variant.price | money }}</p>

  {%- assign size_option = product.options_by_name['Size'] -%}
  {%- if size_option -%}
    <div class="card-section">
      <span class="card-section-label">Size</span>
      <div class="size-options" data-card-sizes>
        {%- for value in size_option.values -%}
          <button class="size-option">{{ value }}</button>
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}

  <div class="product-actions">
    <button class="btn btn-primary" type="button" data-buy-now="{{ default_variant.id }}">Buy Now</button>
  </div>
  <button class="details-link" data-modal-open="{{ product.id }}">View details</button>
</article>
