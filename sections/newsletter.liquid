<section class="newsletter">
  <div class="newsletter-inner">
    {%- if section.settings.heading != blank -%}
      <h2 class="newsletter-heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.body != blank -%}
      <p class="newsletter-body">{{ section.settings.body }}</p>
    {%- endif -%}

    {%- form 'customer', class: 'newsletter-form' -%}
      <input type="hidden" name="contact[tags]" value="newsletter">
      <input type="hidden" name="contact[accepts_marketing]" value="true">

      {%- if form.posted_successfully? -%}
        <p class="newsletter-success">Thanks — you're in.</p>
      {%- else -%}
        <input
          type="email"
          name="contact[email]"
          placeholder="{{ section.settings.placeholder | default: 'your@email.com' }}"
          aria-label="Email address"
          required
        />
        <button type="submit">{{ section.settings.button_text | default: 'Sign up' }}</button>
      {%- endif -%}

      {%- if form.errors -%}
        <p class="newsletter-error">{{ form.errors | default_errors }}</p>
      {%- endif -%}
    {%- endform -%}
  </div>
</section>

{% schema %}
{
  "name": "Newsletter",
  "settings": [
    { "type": "text",     "id": "heading",     "label": "Heading",           "default": "Stay in the loop" },
    { "type": "text",     "id": "body",        "label": "Body",              "default": "Add your email to stay in the loop with Praali." },
    { "type": "text",     "id": "placeholder", "label": "Email placeholder", "default": "your@email.com" },
    { "type": "text",     "id": "button_text", "label": "Button text",       "default": "Sign up" }
  ],
  "presets": [{ "name": "Newsletter" }]
}
{% endschema %}
