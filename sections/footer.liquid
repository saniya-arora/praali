<footer class="site-footer">
  <div class="footer-inner">
    <div class="footer-social">
      {%- if section.settings.instagram_url != blank -%}
        <a href="{{ section.settings.instagram_url }}" target="_blank" rel="noopener" aria-label="Instagram" class="footer-icon">
          <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="3" width="18" height="18" rx="5" />
            <circle cx="12" cy="12" r="4" />
            <circle cx="17.5" cy="6.5" r="0.9" fill="currentColor" stroke="none" />
          </svg>
        </a>
      {%- endif -%}
      {%- if section.settings.tiktok_url != blank -%}
        <a href="{{ section.settings.tiktok_url }}" target="_blank" rel="noopener" aria-label="TikTok" class="footer-icon">
          <svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor">
            <path d="M16.5 3v2.4a4.6 4.6 0 0 0 4.6 4.6V12a7 7 0 0 1-4.6-1.7v6.4a5.3 5.3 0 1 1-5.3-5.3c.3 0 .6 0 .9.1v2.5a2.8 2.8 0 1 0 1.9 2.7V3h2.5z"/>
          </svg>
        </a>
      {%- endif -%}
      {%- if section.settings.contact_email != blank -%}
        <a href="mailto:{{ section.settings.contact_email }}" class="footer-link">{{ section.settings.contact_email }}</a>
      {%- endif -%}
    </div>
    <p class="footer-copy">{{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved</p>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "text",
      "id": "instagram_url",
      "label": "Instagram URL",
      "default": "https://www.instagram.com/"
    },
    {
      "type": "text",
      "id": "tiktok_url",
      "label": "TikTok URL",
      "default": "https://www.tiktok.com/"
    },
    {
      "type": "text",
      "id": "contact_email",
      "label": "Contact email",
      "default": "praalico@gmail.com"
    }
  ]
}
{% endschema %}
