{% doc %}
  @prompt
    create blog section
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-blog-section-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-blog-section__container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
  }

  .ai-blog-section__header-{{ ai_gen_id }} {
    text-align: {{ block.settings.heading_alignment }};
    margin-bottom: 40px;
  }

  .ai-blog-section__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 12px;
  }

  .ai-blog-section__description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0;
  }

  .ai-blog-section__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.grid_gap }}px;
  }

  .ai-blog-section__article-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    background-color: {{ block.settings.card_background_color }};
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .ai-blog-section__article-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 16px rgba(0, 0, 0, 0.1);
  }

  .ai-blog-section__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 66.67%;
    overflow: hidden;
    background-color: #f4f4f4;
  }

  .ai-blog-section__image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-blog-section__image-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-blog-section__image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-blog-section__content-{{ ai_gen_id }} {
    padding: 24px;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
  }

  .ai-blog-section__article-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.article_title_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 12px;
    line-height: 1.3;
  }

  .ai-blog-section__article-title-{{ ai_gen_id }} a {
    color: inherit;
    text-decoration: none;
  }

  .ai-blog-section__article-title-{{ ai_gen_id }} a:hover {
    color: {{ block.settings.link_hover_color }};
  }

  .ai-blog-section__meta-{{ ai_gen_id }} {
    display: flex;
    gap: 16px;
    font-size: 14px;
    color: {{ block.settings.meta_color }};
    margin-bottom: 12px;
  }

  .ai-blog-section__excerpt-{{ ai_gen_id }} {
    font-size: {{ block.settings.excerpt_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0 0 16px;
    line-height: 1.6;
    flex-grow: 1;
  }

  .ai-blog-section__read-more-{{ ai_gen_id }} {
    display: inline-block;
    padding: 10px 20px;
    background-color: {{ block.settings.button_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: 14px;
    transition: background-color 0.3s ease;
    align-self: flex-start;
  }

  .ai-blog-section__read-more-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
  }

  .ai-blog-section__empty-state-{{ ai_gen_id }} {
    text-align: center;
    padding: 60px 20px;
    color: {{ block.settings.meta_color }};
  }

  @media screen and (max-width: 989px) {
    .ai-blog-section__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-blog-section__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    }

    .ai-blog-section__title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.8);
    }

    .ai-blog-section__article-title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.article_title_size }}px * 0.9);
    }
  }
{% endstyle %}

<blog-section-{{ ai_gen_id }} class="ai-blog-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-blog-section__container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank or block.settings.description != blank %}
      <div class="ai-blog-section__header-{{ ai_gen_id }}">
        {% if block.settings.heading != blank %}
          <h2 class="ai-blog-section__title-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
        {% endif %}
        {% if block.settings.description != blank %}
          <div class="ai-blog-section__description-{{ ai_gen_id }}">{{ block.settings.description }}</div>
        {% endif %}
      </div>
    {% endif %}

    {% if block.settings.blog != blank %}
      <div class="ai-blog-section__grid-{{ ai_gen_id }}">
        {% for article in block.settings.blog.articles limit: block.settings.articles_to_show %}
          <article class="ai-blog-section__article-{{ ai_gen_id }}">
            <div class="ai-blog-section__image-wrapper-{{ ai_gen_id }}">
              {% if article.image %}
                <img
                  src="{{ article.image | image_url: width: 800 }}"
                  alt="{{ article.image.alt | escape }}"
                  class="ai-blog-section__image-{{ ai_gen_id }}"
                  loading="lazy"
                  width="800"
                  height="533"
                >
              {% else %}
                <div class="ai-blog-section__image-placeholder-{{ ai_gen_id }}">
                  {{ 'image' | placeholder_svg_tag }}
                </div>
              {% endif %}
            </div>

            <div class="ai-blog-section__content-{{ ai_gen_id }}">
              <h3 class="ai-blog-section__article-title-{{ ai_gen_id }}">
                <a href="{{ article.url }}">{{ article.title }}</a>
              </h3>

              {% if block.settings.show_date or block.settings.show_author %}
                <div class="ai-blog-section__meta-{{ ai_gen_id }}">
                  {% if block.settings.show_date %}
                    <span>{{ article.published_at | date: '%B %d, %Y' }}</span>
                  {% endif %}
                  {% if block.settings.show_author and article.author != blank %}
                    <span>{{ article.author }}</span>
                  {% endif %}
                </div>
              {% endif %}

              {% if block.settings.show_excerpt and article.excerpt != blank %}
                <div class="ai-blog-section__excerpt-{{ ai_gen_id }}">
                  {{ article.excerpt | strip_html | truncate: 150 }}
                </div>
              {% endif %}

              <a href="{{ article.url }}" class="ai-blog-section__read-more-{{ ai_gen_id }}">
                {{ block.settings.read_more_text }}
              </a>
            </div>
          </article>
        {% endfor %}
      </div>
    {% else %}
      <div class="ai-blog-section__empty-state-{{ ai_gen_id }}">
        <p>Next, select a blog to display articles</p>
      </div>
    {% endif %}
  </div>
</blog-section-{{ ai_gen_id }}>

<script>
  (function() {
    class BlogSection{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.setupAccessibility();
      }

      setupAccessibility() {
        const articles = this.querySelectorAll('.ai-blog-section__article-{{ ai_gen_id }}');
        articles.forEach((article) => {
          article.setAttribute('role', 'article');
        });
      }
    }

    customElements.define('blog-section-{{ ai_gen_id }}', BlogSection{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Blog section",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "From the blog"
    },
    {
      "type": "inline_richtext",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "blog",
      "id": "blog",
      "label": "Blog"
    },
    {
      "type": "range",
      "id": "articles_to_show",
      "label": "Articles to show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 3
    },
    {
      "type": "inline_richtext",
      "id": "read_more_text",
      "label": "Read more text",
      "default": "Read more"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
