    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Button background",
      "default": "#5C6B4B"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "button_hover_color",
      "label": "Button hover background",
      "default": "#8AA572"
