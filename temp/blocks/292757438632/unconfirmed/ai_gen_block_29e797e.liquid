{% doc %}
  @prompt
    blog section with 3 articles and hero image
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-blog-hero-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
  }

  .ai-blog-hero__container-{{ ai_gen_id }} {
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    overflow: hidden;
  }

  .ai-blog-hero__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: {{ block.settings.hero_height }}px;
    overflow: hidden;
  }

  .ai-blog-hero__image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-blog-hero__image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-blog-hero__image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
  }

  .ai-blog-hero__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-blog-hero__content-{{ ai_gen_id }} {
    padding: {{ block.settings.content_padding }}px;
  }

  .ai-blog-hero__heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 {{ block.settings.spacing }}px 0;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-blog-hero__description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0 0 {{ block.settings.spacing }}px 0;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-blog-hero__articles-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.article_gap }}px;
  }

  .ai-blog-hero__article-{{ ai_gen_id }} {
    background-color: {{ block.settings.article_bg_color }};
    border-radius: {{ block.settings.article_border_radius }}px;
    overflow: hidden;
    transition: transform 0.3s ease;
  }

  .ai-blog-hero__article-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
  }

  .ai-blog-hero__article-link-{{ ai_gen_id }} {
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .ai-blog-hero__article-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: {{ block.settings.article_image_height }}px;
    overflow: hidden;
  }

  .ai-blog-hero__article-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-blog-hero__article-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-blog-hero__article-image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
  }

  .ai-blog-hero__article-content-{{ ai_gen_id }} {
    padding: {{ block.settings.article_padding }}px;
  }

  .ai-blog-hero__article-date-{{ ai_gen_id }} {
    font-size: 12px;
    color: {{ block.settings.meta_color }};
    margin: 0 0 8px 0;
  }

  .ai-blog-hero__article-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.article_title_size }}px;
    color: {{ block.settings.article_title_color }};
    margin: 0 0 8px 0;
  }

  .ai-blog-hero__article-excerpt-{{ ai_gen_id }} {
    font-size: {{ block.settings.article_excerpt_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0;
  }

  .ai-blog-hero__empty-articles-{{ ai_gen_id }} {
    text-align: center;
    padding: 40px 20px;
    color: #999;
    font-style: italic;
  }

  @media screen and (max-width: 749px) {
    .ai-blog-hero__articles-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    }

    .ai-blog-hero__image-wrapper-{{ ai_gen_id }} {
      height: {{ block.settings.hero_height | times: 0.6 }}px;
    }

    .ai-blog-hero__article-image-wrapper-{{ ai_gen_id }} {
      height: {{ block.settings.article_image_height | times: 0.8 }}px;
    }
  }
{% endstyle %}

<blog-hero-{{ ai_gen_id }} class="ai-blog-hero-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-blog-hero__container-{{ ai_gen_id }}">
    <div class="ai-blog-hero__image-wrapper-{{ ai_gen_id }}">
      {% if block.settings.hero_image %}
        <img
          src="{{ block.settings.hero_image | image_url: width: 2000 }}"
          alt="{{ block.settings.hero_image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.hero_image.width }}"
          height="{{ block.settings.hero_image.height }}"
          class="ai-blog-hero__image-{{ ai_gen_id }}"
        >
      {% else %}
        <div class="ai-blog-hero__image-placeholder-{{ ai_gen_id }}">
          {{ 'hero-apparel-1' | placeholder_svg_tag }}
          <div class="ai-blog-hero__empty-state-{{ ai_gen_id }}">
            Next, add a hero image
          </div>
        </div>
      {% endif %}
    </div>

    <div class="ai-blog-hero__content-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h2 class="ai-blog-hero__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
      {% endif %}

      {% if block.settings.description != blank %}
        <div class="ai-blog-hero__description-{{ ai_gen_id }}">{{ block.settings.description }}</div>
      {% endif %}

      {% if block.settings.blog != blank %}
        {% assign articles = block.settings.blog.articles | limit: 3 %}
        
        {% if articles.size > 0 %}
          <div class="ai-blog-hero__articles-{{ ai_gen_id }}">
            {% for article in articles %}
              <article class="ai-blog-hero__article-{{ ai_gen_id }}">
                <a href="{{ article.url }}" class="ai-blog-hero__article-link-{{ ai_gen_id }}">
                  <div class="ai-blog-hero__article-image-wrapper-{{ ai_gen_id }}">
                    {% if article.image %}
                      <img
                        src="{{ article.image | image_url: width: 600 }}"
                        alt="{{ article.image.alt | escape }}"
                        loading="lazy"
                        width="600"
                        height="400"
                        class="ai-blog-hero__article-image-{{ ai_gen_id }}"
                      >
                    {% else %}
                      <div class="ai-blog-hero__article-image-placeholder-{{ ai_gen_id }}">
                        {{ 'blog-apparel-1' | placeholder_svg_tag }}
                      </div>
                    {% endif %}
                  </div>
                  <div class="ai-blog-hero__article-content-{{ ai_gen_id }}">
                    {% if block.settings.show_date %}
                      <p class="ai-blog-hero__article-date-{{ ai_gen_id }}">{{ article.published_at | date: '%B %d, %Y' }}</p>
                    {% endif %}
                    <h3 class="ai-blog-hero__article-title-{{ ai_gen_id }}">{{ article.title }}</h3>
                    {% if block.settings.show_excerpt and article.excerpt != blank %}
                      <div class="ai-blog-hero__article-excerpt-{{ ai_gen_id }}">{{ article.excerpt | strip_html | truncate: 100 }}</div>
                    {% endif %}
                  </div>
                </a>
              </article>
            {% endfor %}
          </div>
        {% else %}
          <div class="ai-blog-hero__empty-articles-{{ ai_gen_id }}">
            No articles found in this blog
          </div>
        {% endif %}
      {% else %}
        <div class="ai-blog-hero__empty-articles-{{ ai_gen_id }}">
          Next, select a blog to display articles
        </div>
      {% endif %}
    </div>
  </div>
</blog-hero-{{ ai_gen_id }}>

<script>
  (function() {
    class BlogHero{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
      }
    }

    customElements.define('blog-hero-{{ ai_gen_id }}', BlogHero{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Blog hero with articles",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Hero image"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero image"
    },
    {
      "type": "range",
      "id": "hero_height",
      "label": "Hero height",
      "min": 200,
      "max": 600,
      "step": 20,
      "unit": "px",
      "default": 400
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Latest from our blog"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Discover stories, tips, and insights from our team</p>"
    },
    {
      "type": "blog",
      "id": "blog",
      "label": "Blog"
    },
    {
      "type": "checkbox",
      "id": "show_date",
      "label": "Show article date",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_excerpt",
      "label": "Show article excerpt",
      "default": true
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "select",
      "id": "columns_desktop",
      "label": "Columns on desktop",
      "options": [
        {
          "value": "1",
          "label": "1"
        },
        {
          "value": "2",
          "label": "2"
        },
        {
          "value": "3",
          "label": "3"
        }
      ],
      "default": "3"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Columns on mobile",
      "options": [
        {
          "value": "1",
          "label": "1"
        },
        {
          "value": "2",
          "label": "2"
        }
      ],
      "default": "1"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "left"
    },
    {
      "type": "range",
      "id": "content_padding",
      "label": "Content padding",
      "min": 10,
      "max": 60,
      "step": 5,
      "unit": "px",
      "default": 30
    },
    {
      "type": "range",
      "id": "article_gap",
      "label": "Article gap",
      "min": 10,
      "max": 40,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "spacing",
      "label": "Section spacing",
      "min": 10,
      "max": 40,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "header",
      "content": "Article cards"
    },
    {
      "type": "range",
      "id": "article_image_height",
      "label": "Article image height",
      "min": 150,
      "max": 350,
      "step": 10,
      "unit": "px",
      "default": 200
    },
    {
      "type": "range",
      "id": "article_padding",
      "label": "Article padding",
      "min": 10,
      "max": 40,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "article_border_radius",
      "label": "Article border radius",
      "min": 0,
      "max": 30,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size",
      "min": 20,
      "max": 50,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "description_size",
      "label": "Description size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "article_title_size",
      "label": "Article title size",
      "min": 14,
      "max": 28,
      "step": 1,
      "unit": "px",
      "default": 18
    },
    {
      "type": "range",
      "id": "article_excerpt_size",
      "label": "Article excerpt size",
      "min": 12,
      "max": 18,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#EDE8E0"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading",
      "default": "#5C6B4B"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "article_bg_color",
      "label": "Article background",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "article_title_color",
      "label": "Article title",
      "default": "#5C6B4B"
    },
    {
      "type": "color",
      "id": "meta_color",
      "label": "Meta text",
      "default": "#666666"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Container border radius",
      "min": 0,
      "max": 30,
      "step": 2,
      "unit": "px",
      "default": 12
    }
  ],
  "presets": [
    {
      "name": "Blog hero with articles"
    }
  ]
}
{% endschema %}
