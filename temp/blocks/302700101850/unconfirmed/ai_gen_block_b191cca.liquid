{% doc %}
  @prompt
    a blog section
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-blog-section-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-blog-section__container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
  }

  .ai-blog-section__header-{{ ai_gen_id }} {
    text-align: {{ block.settings.text_alignment }};
    margin-bottom: {{ block.settings.header_spacing }}px;
  }

  .ai-blog-section__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 12px;
  }

  .ai-blog-section__description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0;
  }

  .ai-blog-section__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.grid_gap }}px;
    margin-bottom: {{ block.settings.button_spacing }}px;
  }

  .ai-blog-section__article-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
    transition: transform 0.3s ease;
  }

  .ai-blog-section__article-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
  }

  .ai-blog-section__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: {{ block.settings.image_aspect_ratio }}%;
    overflow: hidden;
    background-color: #f4f4f4;
  }

  .ai-blog-section__image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-blog-section__image-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-blog-section__image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-blog-section__content-{{ ai_gen_id }} {
    padding: {{ block.settings.card_padding }}px;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
  }

  .ai-blog-section__article-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.article_title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 8px;
    text-decoration: none;
  }

  .ai-blog-section__article-title-{{ ai_gen_id }}:hover {
    text-decoration: underline;
  }

  .ai-blog-section__meta-{{ ai_gen_id }} {
    font-size: {{ block.settings.meta_size }}px;
    color: {{ block.settings.meta_color }};
    margin-bottom: 12px;
  }

  .ai-blog-section__excerpt-{{ ai_gen_id }} {
    font-size: {{ block.settings.excerpt_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0 0 16px;
    flex-grow: 1;
  }

  .ai-blog-section__read-more-{{ ai_gen_id }} {
    font-size: {{ block.settings.link_size }}px;
    color: {{ block.settings.link_color }};
    text-decoration: none;
    font-weight: 600;
  }

  .ai-blog-section__read-more-{{ ai_gen_id }}:hover {
    text-decoration: underline;
  }

  .ai-blog-section__button-wrapper-{{ ai_gen_id }} {
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-blog-section__button-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_text_size }}px;
    transition: background-color 0.3s ease;
  }

  .ai-blog-section__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
  }

  .ai-blog-section__empty-state-{{ ai_gen_id }} {
    text-align: center;
    padding: 60px 20px;
    color: {{ block.settings.meta_color }};
  }

  @media screen and (max-width: 989px) {
    .ai-blog-section__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_tablet }}, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-blog-section__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    }

    .ai-blog-section__title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.title_size }}px * 0.8);
    }
  }
{% endstyle %}

<blog-section-{{ ai_gen_id }} class="ai-blog-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-blog-section__container-{{ ai_gen_id }}">
    {% if block.settings.title != blank or block.settings.description != blank %}
      <div class="ai-blog-section__header-{{ ai_gen_id }}">
        {% if block.settings.title != blank %}
          <h2 class="ai-blog-section__title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
        {% endif %}
        {% if block.settings.description != blank %}
          <div class="ai-blog-section__description-{{ ai_gen_id }}">{{ block.settings.description }}</div>
        {% endif %}
      </div>
    {% endif %}

    {% if block.settings.blog != blank %}
      {% assign articles_to_show = block.settings.articles_count %}
      
      <div class="ai-blog-section__grid-{{ ai_gen_id }}">
        {% for article in block.settings.blog.articles limit: articles_to_show %}
          <article class="ai-blog-section__article-{{ ai_gen_id }}">
            <div class="ai-blog-section__image-wrapper-{{ ai_gen_id }}">
              {% if article.image %}
                <img
                  src="{{ article.image | image_url: width: 800 }}"
                  alt="{{ article.image.alt | escape }}"
                  class="ai-blog-section__image-{{ ai_gen_id }}"
                  loading="lazy"
                  width="800"
                  height="{{ 800 | divided_by: article.image.aspect_ratio | round }}"
                >
              {% else %}
                <div class="ai-blog-section__image-placeholder-{{ ai_gen_id }}">
                  {{ 'image' | placeholder_svg_tag }}
                </div>
              {% endif %}
            </div>

            <div class="ai-blog-section__content-{{ ai_gen_id }}">
              <a href="{{ article.url }}" class="ai-blog-section__article-title-{{ ai_gen_id }}">
                <h3>{{ article.title }}</h3>
              </a>

              {% if block.settings.show_date or block.settings.show_author %}
                <div class="ai-blog-section__meta-{{ ai_gen_id }}">
                  {% if block.settings.show_author and article.author != blank %}
                    <span>{{ article.author }}</span>
                  {% endif %}
                  {% if block.settings.show_date %}
                    {% if block.settings.show_author and article.author != blank %}
                      <span> • </span>
                    {% endif %}
                    <time datetime="{{ article.published_at | date: '%Y-%m-%d' }}">
                      {{ article.published_at | date: block.settings.date_format }}
                    </time>
                  {% endif %}
                </div>
              {% endif %}

              {% if block.settings.show_excerpt and article.excerpt != blank %}
                <div class="ai-blog-section__excerpt-{{ ai_gen_id }}">
                  {{ article.excerpt | strip_html | truncate: block.settings.excerpt_length }}
                </div>
              {% endif %}

              {% if block.settings.show_read_more %}
                <a href="{{ article.url }}" class="ai-blog-section__read-more-{{ ai_gen_id }}">
                  {{ block.settings.read_more_text }}
                </a>
              {% endif %}
            </div>
          </article>
        {% endfor %}
      </div>

      {% if block.settings.show_view_all and block.settings.blog.url %}
        <div class="ai-blog-section__button-wrapper-{{ ai_gen_id }}">
          <a href="{{ block.settings.blog.url }}" class="ai-blog-section__button-{{ ai_gen_id }}">
            {{ block.settings.button_text }}
          </a>
        </div>
      {% endif %}
    {% else %}
      <div class="ai-blog-section__empty-state-{{ ai_gen_id }}">
        <p>Next, select a blog to display articles</p>
      </div>
    {% endif %}
  </div>
</blog-section-{{ ai_gen_id }}>

<script>
  (function() {
    class BlogSection{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.init();
      }

      init() {
        const articles = this.querySelectorAll('.ai-blog-section__article-{{ ai_gen_id }}');
        articles.forEach((article) => {
          article.addEventListener('mouseenter', function() {
            this.style.boxShadow = '0 8px 16px rgba(0, 0, 0, 0.1)';
          });
          article.addEventListener('mouseleave', function() {
            this.style.boxShadow = 'none';
          });
        });
      }
    }

    customElements.define('blog-section-{{ ai_gen_id }}', BlogSection{{ ai_gen_id }});
  })();
</script>

{% schema %}
